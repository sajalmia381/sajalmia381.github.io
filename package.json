{
  "name": "sajalmia-resume",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tailwind": "tailwindcss -i src/tailwind.css -o src/tailwind.generated.css",
    "tailwind:watch": "tailwindcss -i src/tailwind.css -o src/tailwind.generated.css --watch",
    "start": "npm run tailwind && ng serve --port 4400",
    "build": "npm run tailwind && ng build --base-href /",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "prettier": "prettier --write \"./src/**/*.{js,json,css,scss,less,md,ts,html,component.html}\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular/cli": "~21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@schuchard/prettier": "^5.1.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jasmine": "~4.3.0",
    "angular-cli-ghpages": "^0.6.2",
    "husky": "^8.0.3",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "lint-staged": "^15.1.0",
    "postcss": "^8.4.23",
    "prettier": "^3.1.0",
    "tailwindcss": "^4.3.0",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "~5.9.3"
  },
  "lint-staged": {
    "*.{js,json,css,scss,less,md,ts,html,component.html}": [
      "prettier --write"
    ]
  }
}
